# Application
APP_NAME="INDUS AI API"
APP_VERSION="0.1.0"
APP_ENV="development"
DEBUG=false
LOG_LEVEL="INFO"
API_HOST="0.0.0.0"
API_PORT=8000
CORS_ORIGINS="http://127.0.0.1:3000,http://localhost:3000,http://127.0.0.1:5173,http://localhost:5173"

# Supabase PostgreSQL connection string (copy from Project > Connect)
DATABASE_URL=""
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_TIMEOUT=30

SUPABASE_URL=""
SUPABASE_PUBLISHABLE_KEY=""
SUPABASE_SECRET_KEY=""
SUPABASE_REQUEST_TIMEOUT=20
SUPABASE_STORAGE_BUCKET="documents"
SUPABASE_STORAGE_MAX_FILE_SIZE=52428800
SUPABASE_JWT_AUDIENCE="authenticated"
SUPABASE_JWKS_CACHE_SECONDS=600

SUPABASE_JWT_SECRET=""



# AI provider: gemini (free tier available) or openai
AI_PROVIDER="gemini"
GEMINI_API_KEY=""
GEMINI_EMBEDDING_MODEL="gemini-embedding-001"
GEMINI_CHAT_MODEL="gemini-2.5-flash-lite"
GEMINI_EMBEDDING_BATCH_SIZE=64

# Optional OpenAI fallback
OPENAI_API_KEY=""
OPENAI_EMBEDDING_MODEL="text-embedding-3-small"
OPENAI_EMBEDDING_DIMENSIONS=1536
OPENAI_EMBEDDING_BATCH_SIZE=64
OPENAI_CHAT_MODEL="gpt-5.4-mini"
OPENAI_CHAT_MAX_OUTPUT_TOKENS=1200
OPENAI_REQUEST_TIMEOUT=60
RAG_TOP_K=5
DOCUMENT_CHUNK_TOKENS=800
DOCUMENT_CHUNK_OVERLAP=150
